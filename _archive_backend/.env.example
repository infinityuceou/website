# Environment Variables Template
# Copy to .env and fill in your values

# ====== SERVER CONFIG ======
PORT=5000
MONGO_URI=mongodb://localhost:27017/eventDB
JWT_SECRET=your_secret_key_here

# ====== EMAIL CONFIG (Gmail SMTP) ======
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_here
FROM_EMAIL=your_email@gmail.com

# Optional: Admin notification email
ADMIN_EMAIL=admin@yoursite.com

# ====== UPI CONFIG ======
UPI_ID=yourname@upi

# ====== CLOUDINARY (image storage) ======
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ====== GOOGLE SERVICE ACCOUNT (for Sheets only) ======
# Paste full JSON from service account into this variable (single line, escape newlines in private_key as \\n)
GOOGLE_SERVICE_ACCOUNT_JSON=your_service_account_json_here

# ====== GOOGLE SHEETS CONFIG ======
# Google Sheet where registrations are recorded
GOOGLE_SHEET_ID=your_sheet_id_here

# ====== OPTIONAL ======
VPS_DOMAIN=https://yourdomain.com
PAYEE_NAME=YourName
